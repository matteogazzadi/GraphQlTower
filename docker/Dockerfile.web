FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY ["src/GraphQlTower.Shared/GraphQlTower.Shared.csproj", "GraphQlTower.Shared/"]
COPY ["src/GraphQlTower.Web/GraphQlTower.Web.csproj", "GraphQlTower.Web/"]
RUN dotnet restore "GraphQlTower.Web/GraphQlTower.Web.csproj"

COPY src/GraphQlTower.Shared/ GraphQlTower.Shared/
COPY src/GraphQlTower.Web/ GraphQlTower.Web/
RUN dotnet publish "GraphQlTower.Web/GraphQlTower.Web.csproj" \
    -c Release \
    -o /app/publish \
    --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .

USER $APP_UID
EXPOSE 8080

HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD wget -qO- http://localhost:8080/ || exit 1

ENTRYPOINT ["dotnet", "GraphQlTower.Web.dll"]
