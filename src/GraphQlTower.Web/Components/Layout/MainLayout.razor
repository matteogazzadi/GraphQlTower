@inherits LayoutComponentBase

<FluentLayout>
    <FluentHeader>
        <FluentStack HorizontalAlignment="HorizontalAlignment.Left" VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size24.DataTrending())" Color="Color.Lightweight" />
            <FluentLabel Typo="Typography.H4" Color="Color.Lightweight" Style="margin-left: 8px;">
                GraphQL Tower
            </FluentLabel>
        </FluentStack>
        <FluentSpacer />
        <FluentLabel Color="Color.Lightweight" Style="font-size: 12px; opacity: 0.7;">
            GraphQL Gateway &amp; Aggregator
        </FluentLabel>
    </FluentHeader>

    <FluentBodyContent>
        <FluentNavMenu Width="220" Title="Navigation">
            <FluentNavLink Href="/" Match="NavLinkMatch.All" Icon="@(new Icons.Regular.Size20.Home())">
                Dashboard
            </FluentNavLink>
            <FluentNavLink Href="/services" Icon="@(new Icons.Regular.Size20.CloudLink())">
                Services
            </FluentNavLink>
            <FluentNavLink Href="/playground" Icon="@(new Icons.Regular.Size20.Code())">
                Playground
            </FluentNavLink>
        </FluentNavMenu>

        <FluentBodyContent Style="padding: 24px;">
            @Body
        </FluentBodyContent>
    </FluentBodyContent>

    <FluentFooter>
        <FluentLabel Style="font-size: 12px; opacity: 0.6;">
            GraphQL Tower &copy; @DateTime.Now.Year
        </FluentLabel>
    </FluentFooter>
</FluentLayout>

