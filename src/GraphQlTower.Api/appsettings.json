{
  "ConnectionStrings": {
    "Registry": "Data Source=/data/registry.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "HealthMonitor": {
    "IntervalSeconds": 30
  },
  "AllowedHosts": "*"
}
