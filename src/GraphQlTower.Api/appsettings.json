{
  "ConnectionStrings": {
    "Registry": "Data Source=/data/registry.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "HealthMonitor": {
    "IntervalSeconds": 30
  },
  // Pre-seed upstream services on first boot.
  // Useful when pointing at port-forwarded services locally, or via ConfigMap in K8s.
  // These are only applied when the registry is empty (first boot).
  // After that, manage services via the Admin UI or REST API.
  "InitialServices": [
    // {
    //   "Name": "products",           <- GraphQL schema slug (letters/digits/underscores only)
    //   "DisplayName": "Products",    <- Label shown in the UI
    //   "Url": "http://localhost:8081/graphql",  <- Full GraphQL endpoint URL
    //   "Enabled": true,
    //   "Headers": [
    //     { "Key": "Authorization", "Value": "Bearer <token>" }
    //   ]
    // }
  ],
  "AllowedHosts": "*"
}
